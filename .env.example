# Telegram Bot Token
BOT_TOKEN=your_bot_token_here

# Database
DB_HOST=localhost
DB_USER=finot_user
DB_PASSWORD=password_finot
DB_NAME=finot_bot_db
DB_PORT=5432
DATABASE_URL=postgresql://finot_user:password_finot@localhost:5432/finot_bot_db

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Trakteer API (for QRIS Payment)
TRAKTEER_API_KEY=your_trakteer_api_key_here
TRAKTEER_WEBHOOK_SECRET=your_trakteer_webhook_secret_here
TRAKTEER_PAGE_URL=https://trakteer.id/your-username

# Webhook / Domain
WEBHOOK_URL=https://fi-note.app

# Email / SMTP (magic links: email verification & password reset)
# For Gmail: enable 2-Step Verification, then create an App Password (16 chars).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=twentistudio@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
SMTP_FROM=FiNot <twentistudio@gmail.com>
# Public base URL used to build magic links (no trailing slash)
APP_BASE_URL=https://fi-note.app

# Admin Dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# Environment
DEPLOYMENT_ENV=development
